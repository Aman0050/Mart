# ── App ─────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://nexmarto:password@localhost:5432/nexmarto_dev
SHADOW_DATABASE_URL=postgresql://nexmarto:password@localhost:5432/nexmarto_shadow
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-to-a-32-char-random-secret-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-32-char-random-secret
JWT_REFRESH_EXPIRES_IN=7d

# ── AWS S3 ───────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=nexmarto-uploads
AWS_S3_URL=https://nexmarto-uploads.s3.ap-south-1.amazonaws.com

# ── Payments (Razorpay) ──────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Email (Resend / SMTP) ────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=
EMAIL_FROM=noreply@nexmarto.com

# ── Frontend (public) ────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ── Monitoring ───────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
